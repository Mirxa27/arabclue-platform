# ── ArabClue local / production ──
# Copy this to .env and fill secrets. Never commit .env.

# 1) Database — Neon Postgres (pooled URL recommended for serverless)
# Local: postgresql://USER:PASSWORD@localhost:5432/arabclue?schema=public
# Neon:  postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/arabclue?schema=public"

# 2) NextAuth — canonical URL + secret (use `openssl rand -base64 32`)
# Production: https://arabclue.com
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-long-random-string-min-32-chars"

# 3) Bootstrap admin (first seed only) — password min 10 chars
BOOTSTRAP_ADMIN_EMAIL="admin@arabclue.com"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-strong-password-min-10"

# 4) Encrypts admin EnvSetting values (AES-256-GCM) — required in production
ARABCLUE_ENC_KEY="replace-with-long-random-encryption-key-32+chars"

# 5) Vercel Blob (production uploads) — set via Vercel storage integration
# BLOB_READ_WRITE_TOKEN=

# 6) Optional LLM providers (also configurable in Admin → AI Providers UI)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ZAI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=

# 7) MyFatoorah payments (Saudi VAT/compliant)
# Test: https://apitest.myfatoorah.com
# Live SA: https://api-sa.myfatoorah.com
# MYFATOORAH_API_KEY=
# MYFATOORAH_API_URL=https://apitest.myfatoorah.com
# MYFATOORAH_WEBHOOK_SECRET=

# 8) Optional local overrides
# NODE_ENV=development
# PORT=3000
