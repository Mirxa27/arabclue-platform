# Copy to .env and fill in real values. Never commit .env.

# Database — SQLite for local; use Postgres URL in production
DATABASE_URL="file:./db/custom.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-long-random-string"

# Bootstrap admin (required on first seed)
BOOTSTRAP_ADMIN_EMAIL="admin@arabclue.sa"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-strong-password-min-8"

# Encrypts EnvSetting values in admin (required in production)
ARABCLUE_ENC_KEY="replace-with-long-random-encryption-key"

# Optional LLM providers (configure in Admin → AI providers or here)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# MyFatoorah payments (Saudi)
# Test: https://apitest.myfatoorah.com
# Live SA: https://api-sa.myfatoorah.com
# MYFATOORAH_API_KEY=
# MYFATOORAH_API_URL=https://apitest.myfatoorah.com
# MYFATOORAH_WEBHOOK_SECRET=
