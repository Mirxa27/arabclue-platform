{
  "name": "arabclue-platform",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "bun run db:ensure && next dev -p 3000",
    "dev:log": "next dev -p 3000 2>&1 | tee dev.log",
    "dev:setup": "bun run db:ensure && bun run db:generate && bun run db:push:dev && echo '✅ Setup done — run bun run dev'",
    "dev:clean": "rm -rf .next db/custom.db dev.log && bun run db:ensure && bun run db:generate && bun run db:push:dev",
    "pack:extension": "bun scripts/pack-extension.mjs",
    "build": "bun run pack:extension && prisma generate && next build",
    "build:schema-sql": "node scripts/embed-schema-sql.mjs",
    "build:vercel": "bun run pack:extension && prisma generate && prisma migrate deploy && next build",
    "build:standalone": "STANDALONE=1 bun run pack:extension && STANDALONE=1 prisma generate && STANDALONE=1 next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "deploy:check": "bun run lint && bun run test && bun run build",
    "start": "NODE_ENV=production bun .next/standalone/server.js",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "test": "bun test src/lib/__tests__",
    "db:ensure": "mkdir -p db uploads && touch db/.gitkeep && touch uploads/.gitkeep",
    "db:push": "prisma db push",
    "db:push:dev": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio"
  },
  "dependencies": {
