{
  "manifest_version": 3,
  "name": "ArabClue Voice Agent",
  "version": "1.1.0",
  "description": "Give ArabClue Mission Control superpowers: capture any page, selection, or screenshot into the Voice AI agent with live glitter FX.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Open ArabClue Voice Agent",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://arabclue.com/*",
    "https://*.arabclue.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://arabclue.com/*",
      "https://*.arabclue.com/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://arabclue.com/*",
        "https://*.arabclue.com/*"
      ],
      "js": ["content/arabclue-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
