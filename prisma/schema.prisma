// Prisma schema for Arabclue — Saudi Government Tender Proposal Automation SaaS
// Production domain model: RBAC + MFA users, workspaces, tender projects,
// versioned documents, brand profiles, past projects (RAG), multi-agent runs,
// NCA/PDPL compliance checks, generated proposals, AI provider config,
// encrypted env settings, subscriptions/billing, and immutable audit trail.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Identity & Access (RBAC + MFA) ──────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  passwordHash    String
  role            String   @default("BIDDER") // SUPER_ADMIN | ADMIN | BIDDER | REVIEWER | FINANCE
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String?
  avatarUrl       String?
  locale          String   @default("ar") // ar | en
  active          Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  activeWorkspaceId String?
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaces      WorkspaceMember[]
  projects        TenderProject[]
  documents       UploadedDocument[]
  proposals       GeneratedProposal[]
  agentRuns       AgentRun[]
  sessions        UserSession[]
  auditLogs       AuditLog[]
  billingRecords  BillingRecord[]
  paymentCheckouts PaymentCheckout[]
  subscription    Subscription?
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Workspaces (multi-tenant) ───────────────────────────────────────────────

model Workspace {
  id            String   @id @default(cuid())
  name          String
  nameAr        String?
  slug          String   @unique
  plan          String   @default("ENTERPRISE") // STARTER | PRO | ENTERPRISE
  crNumber      String?  // Commercial Registration
  vatNumber     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       WorkspaceMember[]
  projects      TenderProject[]
  documents     UploadedDocument[]
  brandProfiles BrandProfile[]
  pastProjects  PastProject[]
  proposals     GeneratedProposal[]
}

model WorkspaceMember {
  id           String   @id @default(cuid())
  workspaceId  String
  userId       String
  role         String   @default("MEMBER") // OWNER | ADMIN | MEMBER
  createdAt    DateTime @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ─── Tender Projects ─────────────────────────────────────────────────────────

model TenderProject {
  id               String   @id @default(cuid())
  workspaceId      String
  createdById      String
  etimadRef        String?  // Etimad tender reference number
  title            String
  titleAr          String?
  category         String?  // IT | CONSULTING | CONSTRUCTION | MEDICAL | GENERAL
  budget           Float?
  currency         String   @default("SAR")
  submissionDeadline DateTime?
  status           String   @default("DRAFT") // DRAFT | PARSING | DRAFTING | REVIEW | SUBMITTED | ARCHIVED
  saudizationTarget Float?  // percentage
  localContentTarget Float? // percentage
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy        User      @relation(fields: [createdById], references: [id])
  documents        UploadedDocument[]
  proposals        GeneratedProposal[]
  agentRuns        AgentRun[]
  complianceChecks ComplianceCheck[]

  @@index([workspaceId])
  @@index([status])
}

// ─── Uploaded Documents (versioned) ──────────────────────────────────────────

model UploadedDocument {
  id              String   @id @default(cuid())
  workspaceId     String
  projectId       String?
  uploadedById    String
  originalName    String
  storagePath     String
  mimeType        String
  sizeBytes       Int
  docCategory     String   // RFP | TECHNICAL_SPECS | IT_CONTRACT | EA_COMPLIANCE | QUALIFICATION | FINANCIAL | BRAND_ASSET | OTHER
  docTypeAr       String?
  checksum        String?
  currentVersion  Int      @default(1)
  parseStatus     String   @default("PENDING") // PENDING | PARSING | PARSED | FAILED
  parsedSummary   String?
  extractedEntities String? // JSON blob of extracted SOW/SLA/milestones
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         TenderProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedBy      User      @relation(fields: [uploadedById], references: [id])
  versions        DocumentVersion[]
  chunks          DocumentChunk[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([docCategory])
}

// RAG chunks from uploaded tender documents (RFP, specs, contracts, etc.)
model DocumentChunk {
  id            String   @id @default(cuid())
  documentId    String
  workspaceId   String
  projectId     String?
  chunkIndex    Int
  content       String
  embeddingJson String?  // JSON number[] for dense retrieval
  createdAt     DateTime @default(now())

  document      UploadedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([workspaceId])
  @@index([projectId])
  @@index([documentId])
}

model DocumentVersion {
  id                 String   @id @default(cuid())
  documentId         String
  version            Int
  storagePath        String
  sizeBytes          Int
  changeLog          String?
  parsedSummary      String?
  extractedEntities  String?
  checksum           String?
  createdBy          String
  createdAt          DateTime @default(now())
  document           UploadedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
}

// ─── Brand Profiles & Past Projects (RAG corpus) ────────────────────────────

model BrandProfile {
  id            String   @id @default(cuid())
  workspaceId   String
  logoUrl       String?
  primaryColor  String   @default("#1E3A8A")
  secondaryColor String  @default("#0F172A")
  accentColor   String   @default("#0EA5E9")
  fontFamily    String   @default("IBM Plex Sans Arabic")
  tagline       String?
  taglineAr     String?
  vision2030Alignment String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pastProjects  PastProject[]
}

model PastProject {
  id             String   @id @default(cuid())
  workspaceId    String
  brandProfileId String?
  title          String
  titleAr        String?
  clientName     String?
  clientNameAr   String?
  sector         String?  // GOV | HEALTH | FINANCE | ENERGY | TELECOM | OTHER
  contractValue  Float?
  currency       String   @default("SAR")
  startDate      DateTime?
  endDate        DateTime?
  outcome        String?  // SUCCESSFUL | ONGOING | COMPLETED
  summary        String   // rich text / vectorized for RAG
  summaryAr      String?
  vectorId       String?  // optional external vector store id
  embeddingJson  String?  // JSON number[] embedding for local RAG
  tags           String?  // comma-separated
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandProfile   BrandProfile? @relation(fields: [brandProfileId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([sector])
}

// ─── Multi-Agent Workflow Runs ───────────────────────────────────────────────

model AgentRun {
  id            String   @id @default(cuid())
  projectId     String
  triggeredById String
  status        String   @default("QUEUED") // QUEUED | RUNNING | COMPLETED | FAILED | CANCELLED
  startedAt     DateTime?
  completedAt   DateTime?
  overallProgress Float  @default(0) // 0-100
  agentStates   String?  // JSON: per-agent status/progress/output
  finalArtifact String?  // JSON summary of generated artifacts
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       TenderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy   User          @relation(fields: [triggeredById], references: [id])

  @@index([projectId])
  @@index([status])
}

// ─── Compliance Checks (NCA / PDPL / EA) ────────────────────────────────────

model ComplianceCheck {
  id            String   @id @default(cuid())
  projectId     String
  framework     String   // NCA_ECC1 | NCA_CCC1 | PDPL | EA_TP1 | EA_SP1 | EA_SP2 | LOCAL_CONTENT
  controlId     String   // e.g. ECC-1.3, PDPL-14, TP1-CloudFirst
  title         String
  titleAr       String?
  requirement   String
  status        String   @default("PENDING") // PENDING | COMPLIANT | PARTIAL | NON_COMPLIANT | NOT_APPLICABLE
  complianceLevel String? // C1 (Full) | C2 (Substantial) | C3 (Partial)
  evidence      String?
  remediation   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       TenderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([framework])
}

// ─── Generated Proposals ─────────────────────────────────────────────────────

model GeneratedProposal {
  id            String   @id @default(cuid())
  workspaceId   String
  projectId     String
  createdById   String
  title         String
  titleAr       String?
  type          String   // TECHNICAL | FINANCIAL | EA_MATRIX | BOQ | COMBINED
  status        String   @default("DRAFT") // DRAFT | GENERATED | REVIEWED | EXPORTED
  version       Int      @default(1)
  contentMd     String?  // markdown content
  locale        String   @default("ar") // ar | en — generation language
  artifactsJson String?  // JSON: list of {type, filename, downloadPath}
  complianceScore Float? // 0-100
  generatedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       TenderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User      @relation(fields: [createdById], references: [id])
  versions      ProposalVersion[]

  @@index([workspaceId])
  @@index([projectId])
}

model ProposalVersion {
  id          String   @id @default(cuid())
  proposalId  String
  version     Int
  contentMd   String
  changeLog   String?
  locale      String   @default("ar")
  createdBy   String
  createdAt   DateTime @default(now())
  proposal    GeneratedProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, version])
  @@index([proposalId])
}

// ─── AI Provider & Model Configuration ───────────────────────────────────────

model AIProviderConfig {
  id              String   @id @default(cuid())
  name            String   // e.g. "ZAI GLM-4.6", "OpenAI GPT-4o", "Claude Sonnet"
  provider        String   // zai | openai | anthropic | mistral | openai_compatible | ollama | azure_openai
  modelId         String   // e.g. glm-4.6, gpt-4o, claude-3-5-sonnet
  apiBase         String?  // OpenAI-compatible base URL ending in /v1 or host root
  apiKeyEnvKey    String?  // EnvSetting / process.env key for the API token
  // Which agent engine this config serves (one active provider per engine)
  engine          String   @default("DEFAULT") // DEFAULT | INGESTION | COMPLIANCE | TECHNICAL | FINANCIAL | DRAFTING | EMBEDDING | REWRITE
  isActive        Boolean  @default(false)
  isDefault       Boolean  @default(false)
  priority        Int      @default(0)
  // Model capabilities (auto-filled from catalog / model list)
  contextWindow   Int      @default(128000)
  supportsVision  Boolean  @default(false)
  supportsJsonMode Boolean @default(true)
  supportsTools   Boolean  @default(false)
  // Tunable parameters
  temperature     Float    @default(0.2)
  maxTokens       Int      @default(4096)
  topP            Float    @default(0.9)
  frequencyPenalty Float   @default(0.0)
  presencePenalty Float    @default(0.0)
  // Safety guardrails
  confidenceThreshold Float @default(0.85)
  toxicityFilter  Boolean  @default(true)
  piiFilter       Boolean  @default(true)
  hallucinationGuard Boolean @default(true)
  maxRetries      Int      @default(2)
  timeoutMs       Int      @default(60000)
  // Cost tracking
  inputCostPer1k  Float    @default(0.0)
  outputCostPer1k Float    @default(0.0)
  metadata        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([provider])
  @@index([isActive])
  @@index([engine])
  @@index([engine, isActive])
}

// ─── Encrypted Environment Settings (.env UI management) ─────────────────────

model EnvSetting {
  id            String   @id @default(cuid())
  key           String   @unique // e.g. OPENAI_API_KEY, DATABASE_URL, WEBHOOK_URL
  valueEncrypted String  // AES-256-GCM encrypted ciphertext (iv:authTag:ciphertext)
  category      String   @default("GENERAL") // AI_PROVIDER | DATABASE | INTEGRATION | SECURITY | BILLING | GENERAL
  description   String?
  isSecret      Boolean  @default(true) // mask in UI
  isRequired    Boolean  @default(false)
  lastRotatedAt DateTime?
  lastEditedBy  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
}

// ─── Subscriptions & Billing ─────────────────────────────────────────────────

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   // STARTER | PRO | ENTERPRISE | PAY_AS_YOU_GO
  nameAr          String?
  description     String?
  priceMonthly    Float    @default(0.0) // SAR
  priceYearly     Float    @default(0.0) // SAR
  currency        String   @default("SAR")
  // Quotas
  maxProposals    Int      @default(10) // per month; -1 = unlimited
  maxDocuments    Int      @default(50)
  maxWorkspaces   Int      @default(1)
  maxTokensPerMonth Int    @default(500000) // LLM token budget
  maxStorageGb    Int      @default(5)
  // Features
  featuresJson    String?  // JSON array of feature flags
  isActive        Boolean  @default(true)
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]
  paymentCheckouts PaymentCheckout[]
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  planId          String
  status          String   @default("ACTIVE") // ACTIVE | PAST_DUE | CANCELLED | TRIALING | EXPIRED
  billingCycle    String   @default("MONTHLY") // MONTHLY | YEARLY
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  // Usage counters (reset each cycle)
  proposalsUsed   Int      @default(0)
  documentsUsed   Int      @default(0)
  tokensUsed      Int      @default(0)
  storageUsedBytes Float   @default(0)
  trialEndsAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([status])
}

model BillingRecord {
  id              String   @id @default(cuid())
  userId          String
  type            String   // SUBSCRIPTION | USAGE | TOPUP | REFUND | OVERAGE
  amount          Float    // SAR
  currency        String   @default("SAR")
  description     String
  tokensIncluded  Int      @default(0)
  proposalsIncluded Int    @default(0)
  status          String   @default("PAID") // PENDING | PAID | FAILED | REFUNDED
  invoiceNumber   String?
  paymentMethod   String?  // myfatoorah | mada | visa | mastercard | stc_pay | bank_transfer
  externalInvoiceId String? // MyFatoorah InvoiceId
  externalPaymentId String?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkout        PaymentCheckout?

  @@index([userId])
  @@index([status])
  @@index([externalInvoiceId])
}

// MyFatoorah checkout sessions for self-serve plan purchase
model PaymentCheckout {
  id                String   @id @default(cuid())
  userId            String
  planId            String
  billingCycle      String   // MONTHLY | YEARLY
  amount            Float
  currency          String   @default("SAR")
  status            String   @default("PENDING") // PENDING | PAID | FAILED | EXPIRED | CANCELLED
  customerReference String   @unique
  invoiceId         String?  // MyFatoorah InvoiceId (stringified)
  paymentId         String?
  paymentUrl        String?
  billingRecordId   String?  @unique
  errorMessage      String?
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
  billingRecord     BillingRecord? @relation(fields: [billingRecordId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([invoiceId])
}

// ─── Immutable Audit Trail ───────────────────────────────────────────────────

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  action          String   // LOGIN | LOGOUT | CONFIG_CHANGE | DOC_UPLOAD | PROPOSAL_GENERATE | ROLE_CHANGE | ENV_UPDATE | BILLING_CHANGE
  resource        String?  // affected entity type
  resourceId      String?  // affected entity id
  details         String?  // JSON blob with before/after
  ipAddress       String?
  userAgent       String?
  severity        String   @default("INFO") // INFO | WARN | ERROR | CRITICAL
  success         Boolean  @default(true)
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
